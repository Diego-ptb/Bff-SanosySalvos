# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Microservices URLs (internal Docker network)
AUTH_SERVICE_URL=http://auth-service:8080
VET_SERVICE_URL=http://vet-service:8081
PET_SERVICE_URL=http://pet-service:8082
PROFILE_SERVICE_URL=http://profile-service:8083

# HTTP Client Configuration
HTTP_TIMEOUT_MS=5000
HTTP_MAX_RETRIES=3

# Redis (for caching and distributed tracing context)
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,https://app.sanosysalvos.cl

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Health Checks
HEALTH_CHECK_TIMEOUT_MS=5000
